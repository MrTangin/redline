# Redline environment variables
#
# Only the variables for modules enabled in lib/project.config.ts are
# required. Running `pnpm run setup` (or `pnpm run add:<module>`) appends
# the right block below automatically — you shouldn't need to edit this
# file by hand for a normal setup.

# --- database (Supabase) — required, powers webhook inbox persistence ---
# Create a project at supabase.com, run supabase/schema.sql in its SQL
# editor, then fill these in from Project Settings > API.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- auth (Clerk) — required if modules.auth is true ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# --- analytics (PostHog) — required if modules.analytics is true ---
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# --- monitoring (Sentry) — required if modules.monitoring is true ---
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
